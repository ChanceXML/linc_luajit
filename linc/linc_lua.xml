<xml>

    <files id="haxe">
        <compilerflag value="-I${LINC_LUA_PATH}/linc/"/>

        <section if="android">
            <compilerflag value="-DLUAJIT_ENABLE_GC64" if="HXCPP_ARM64"/>
            <compilerflag value="-DLUAJIT_ENABLE_GC64" if="HXCPP_X86_64"/>
        </section>

        <file name="${LINC_LUA_PATH}/linc/linc_lua.cpp"/>
    </files>

    <files id="__main__">
        <compilerflag value="-I${LINC_LUA_PATH}/linc/"/>
    </files>

    <section id="vars">
        <set name="NO_PRECOMPILED_HEADERS" value="1"/>
    </section>

    <target id="haxe">

        <!-- Windows -->
        <section if="windows" unless="mingw">
            <lib name="${LINC_LUA_PATH}lib/lua/lib/Windows64/lua51.lib" if="HXCPP_M64"/>
            <lib name="${LINC_LUA_PATH}lib/lua/lib/Windows/lua51.lib" if="HXCPP_M32"/>
        </section>

        <section if="mingw">
            <lib name="${LINC_LUA_PATH}lib/lua/lib/Windows64/libluajit-5.1.a" if="HXCPP_M64"/>
            <lib name="${LINC_LUA_PATH}lib/lua/lib/Windows/libluajit-5.1.a" if="HXCPP_M32"/>
        </section>

        <!-- Linux -->
        <section if="linux">
            <lib name="${LINC_LUA_PATH}/lib/lua/lib/Linux64/libluajit.a" if="HXCPP_M64"/>
        </section>

        <!-- Mac -->
        <section if="mac">
            <lib name="${LINC_LUA_PATH}/lib/lua/lib/Mac/libluajit-5.1.a" if="HXCPP_ARM64 || HXCPP_M64"/>
        </section>

        <!-- Android -->
        <section if="android">

            <compilerflag value="-DLUAJIT_ENABLE_LUA52COMPAT"/>
            <compilerflag value="-DLUAJIT_UNWIND_EXTERNAL"/>

            <lib name="${LINC_LUA_PATH}/lib/lua/lib/Android/arm64-v8a/libluajit-v7.a" if="HXCPP_ARMV7"/>
            <lib name="${LINC_LUA_PATH}/lib/lua/lib/Android/armeabi-v7a/libluajit-64.a" if="HXCPP_ARM64"/>
            <lib name="${LINC_LUA_PATH}/lib/lua/lib/Android/x86/libluajit-x86.a" if="HXCPP_X86"/>
            <lib name="${LINC_LUA_PATH}/lib/lua/lib/Android/x86_64/libluajit-x86_64.a" if="HXCPP_X86_64"/>

            <linkerflag value="-lm"/>
            <linkerflag value="-ldl"/>
        </section>

        <!-- iOS -->
        <section if="ios">
            <section if="iphoneos">
                <lib name="${LINC_LUA_PATH}/lib/lua/lib/iPhone/libluajit.iphoneos-64.a" if="HXCPP_ARM64"/>
            </section>
            <section if="iphonesim">
                <lib name="${LINC_LUA_PATH}/lib/lua/lib/iPhone/libluajit.iphonesim-64.a" if="HXCPP_ARM64"/>
            </section>
        </section>

    </target>

</xml>
